<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.addedit.AddEditArtifactFragment">
    <!-- Since we have a lot to display, we can use a Linear Layout -->
    <!-- Instead of a Constraint Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <!-- Image picker box -->
        <FrameLayout
            android:id="@+id/image_picker_container"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/image_picker_box"
            android:clickable="true"
            android:focusable="true">
            <!-- Where the image will be once we actually select one -->
            <ImageView
                android:id="@+id/image_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Selected artifact image preview"
                android:scaleType="centerCrop"
                android:visibility="gone" />
            <!-- Until then, display an image widget with text -->
            <LinearLayout
                android:id="@+id/image_placeholder_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="null"
                    android:importantForAccessibility="no"
                    android:src="@android:drawable/ic_menu_gallery" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tap to add image"
                    android:textColor="#757575" />
            </LinearLayout>
        </FrameLayout>

        <Button
            android:id="@+id/select_image_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Select Image" />

        <!-- Lot Number [mandatory] -->
        <EditText
            android:id="@+id/lot_number_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lot Number"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Artifact Name [mandatory] -->
        <EditText
            android:id="@+id/name_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Artifact Name"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Description [mandatory] -->
        <EditText
            android:id="@+id/description_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="Description"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3" />

        <!-- Category [mandatory] -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Category" />
        <Spinner
            android:id="@+id/category_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/category_options" />

        <!-- Material [mandatory] -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Material" />
        <Spinner
            android:id="@+id/material_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/material_options" />

        <!-- Dynasty/Period (mandatory, fixed options) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Dynasty / Period" />
        <Spinner
            android:id="@+id/dynasty_period_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/dynasty_period_options" />

        <!-- Cultural Origin [optional] -->
        <EditText
            android:id="@+id/cultural_origin_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Cultural Origin"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Dimensions [optional] -->
        <EditText
            android:id="@+id/dimensions_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Dimensions"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Condition Report [optional] -->
        <EditText
            android:id="@+id/condition_report_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="Condition Report"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2" />

        <!-- Current Location [optional] -->
        <EditText
            android:id="@+id/current_location_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Current Location"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Acquisition Method [optional] -->
        <EditText
            android:id="@+id/acquisition_method_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Acquisition Method"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Provenance [optional] -->
        <EditText
            android:id="@+id/provenance_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="Provenance"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2" />

        <!-- Accession Number [optional] -->
        <EditText
            android:id="@+id/accession_number_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Accession Number"
            android:inputType="text"
            android:minHeight="48dp" />

        <!-- Notes [optional] -->
        <EditText
            android:id="@+id/notes_field"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="top|start"
            android:hint="Notes"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="2" />
        <!-- Save Artifact -->
        <Button
            android:id="@+id/save_artifact_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Save" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>