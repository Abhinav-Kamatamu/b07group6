<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/navigation_graph"
    app:startDestination="@id/loginFragment">

    <action
        android:id="@+id/action_global_to_home"
        app:destination="@id/homeFragment" />
    <action
        android:id="@+id/action_global_to_add_edit"
        app:destination="@id/addEditArtifactFragment" />
    <action
        android:id="@+id/action_global_to_profile"
        app:destination="@id/homeFragment" />
    <action
        android:id="@+id/action_global_to_saved"
        app:destination="@id/homeFragment" />

    <!-- LoginFragment -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.b07group6.ui.login.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <!-- Transition to HomeFragment -->
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <!-- Transition to CreateAccountFragment -->
        <action
            android:id="@+id/action_create_account"
            app:destination="@id/createAccountFragment"/>

    </fragment>
    <!-- CreateAccountFragment -->
    <fragment
        android:id="@+id/createAccountFragment"
        android:name="com.example.b07group6.ui.createaccount.CreateAccountFragment"
        android:label="Create Account"
        tools:layout="@layout/fragment_create_account">
        <!-- Transition to HomeFragment -->
        <action
            android:id="@+id/action_create_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- HomeFragment -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.b07group6.ui.home.HomeFragment"
        android:label="Main Home"
        tools:layout="@layout/fragment_home">
        <!-- Transition to AddEditArtifactFragment -->
        <action
            android:id="@+id/action_home_to_add_edit_artifact"
            app:destination="@id/addEditArtifactFragment" />
    </fragment>
    <!-- AddEditArtifactFragment -->
    <fragment
        android:id="@+id/addEditArtifactFragment"
        android:name="com.example.b07group6.ui.addedit.AddEditArtifactFragment"
        android:label="Add or Edit Artifact"
        tools:layout="@layout/fragment_add_edit_artifact">
        <!-- Transition to HomeFragment -->
        <action
            android:id="@+id/action_add_edit_artifact_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/addEditArtifactFragment"
            app:popUpToInclusive="true" />
    </fragment>
</navigation>
