<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Image displayed when the SAVED button is checked (ON state) -->
    <item android:state_checked="true" android:drawable="@drawable/ic_bookmark_filled" />

    <!-- Image displayed when the SAVED button is unchecked (OFF state) -->
    <item android:state_checked="false" android:drawable="@drawable/ic_bookmark" />
</selector>
